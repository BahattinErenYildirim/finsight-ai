# =============================================================================
# FinSight AI — Environment variables
# =============================================================================
#
# Copy to .env and fill in values:
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (Linux/macOS)
#
# -----------------------------------------------------------------------------

# LLM provider for AI reports: gemini (cloud) | ollama (local)
LLM_PROVIDER=ollama

# Ollama (when LLM_PROVIDER=ollama)
# Install: https://ollama.com — model: ollama pull RefinedNeuro/RN_TR_R2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=RefinedNeuro/RN_TR_R2
OLLAMA_TIMEOUT=300

# Gemini (when LLM_PROVIDER=gemini)
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=3

# Backend API security (change in production: openssl rand -hex 32)
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (default dev SQLite)
DATABASE_URL=sqlite+aiosqlite:///./finsight_dev.db
# Production example:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/finsight
DB_ECHO=false

# Redis (optional — in-memory fallback if unset)
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Monitoring (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
ENV=development

# Scheduler tickers (optional)
TRACKED_TICKERS=THYAO,ASELS,GARAN,SISE,EREGL,KCHOL,AKBNK,YKBNK,TOASO,FROTO
